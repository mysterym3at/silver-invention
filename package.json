{
   "name": "vendula-handbags",
   "version": "2.0.0",
   "type": "module",
   "private": true,
   "dependencies": {
      "@emotion/react": "^11.14.0",
      "@emotion/styled": "^11.14.1",
      "@mui/icons-material": "^7.3.2",
      "@mui/material": "^7.3.2",
      "axios": "^1.11.0",
      "dotenv": "^17.2.1",
      "firebase": "^12.4.0",
      "firebase-admin": "^13.8.0",
      "form-data": "^4.0.4",
      "fs": "^0.0.1-security",
      "gh-pages": "^6.3.0",
      "hono": "^4.12.15",
      "node-fetch": "^3.3.2",
      "react": "^18.3.1",
      "react-dom": "^18.3.1",
      "react-router-dom": "^6.30.1",
      "xml2js": "^0.6.2"
   },
   "scripts": {
      "start": "concurrently \"npm run start:react\" \"cd api && npx wrangler dev\"",
      "start:react": "react-scripts start",
      "build": "react-scripts build",
      "test": "react-scripts test",
      "eject": "react-scripts eject",
      "deploy": "firebase deploy",
      "predeploy": "npm run build",
      "deploy-gh": "gh-pages -d build",
      "backup": "npx wrangler d1 export \"vendula-bags-db\" --remote --output=api/production_backup.sql --y",
      "clear-sql": "node -e \"const fs = require('fs'); const glob = require('glob'); glob.sync('api/sql/**/*.sql').forEach(f => fs.truncateSync(f, 0));\"",
       "clear-collections": "node -e \"const fs = require('fs'); const glob = require('glob'); glob.sync('api/sql/collections/*.sql').forEach(f => fs.truncateSync(f, 0));\"",
      "clear-shapes": "node -e \"const fs = require('fs'); const glob = require('glob'); glob.sync('api/sql/shapes/*.sql').forEach(f => fs.truncateSync(f, 0));\"",
      "clear-designs": "node -e \"const fs = require('fs'); const glob = require('glob'); glob.sync('api/sql/shapes/*.sql').forEach(f => fs.truncateSync(f, 0));\""

   },
   "eslintConfig": {
      "extends": [
         "react-app",
         "react-app/jest"
      ]
   },
   "browserslist": {
      "production": [
         ">0.2%",
         "not dead",
         "not op_mini all"
      ],
      "development": [
         "last 1 chrome version",
         "last 1 firefox version",
         "last 1 safari version"
      ]
   },
   "devDependencies": {
      "@testing-library/jest-dom": "^6.8.0",
      "concurrently": "^9.2.1",
      "glob": "^13.0.6",
      "react-scripts": "^5.0.1",
      "web-vitals": "^5.1.0"
   },
   "description": "Schema: Applying the Schema Apply to local:",
